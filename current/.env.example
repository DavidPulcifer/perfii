APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
APP_DISPLAY_NAME=Perfii

HOST=127.0.0.1
PORT=8080

APP_DATA_DIR=/srv/finance-app/data
DB_PATH=/srv/finance-app/data/data.sqlite
META_DB_PATH=/srv/finance-app/data/meta.sqlite
USER_DB_DIR=/srv/finance-app/data/user_dbs
UPLOAD_DIR=/srv/finance-app/data/uploads

SESSION_COOKIE_SECURE=1
TRUST_PROXY_HEADERS=1

WEB_CONCURRENCY=1
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120

SQLITE_TIMEOUT_SECONDS=30
SQLITE_BUSY_TIMEOUT_MS=30000
SQLITE_JOURNAL_MODE=WAL
