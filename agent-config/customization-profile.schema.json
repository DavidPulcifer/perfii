{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/finance-app/customization-profile.schema.json",
  "title": "Finance App coding-agent customization profile",
  "description": "A requirements brief for a coding agent. It is not runtime configuration and must not contain credentials or real financial records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "profile_name",
    "requirements_status",
    "project",
    "requested_changes",
    "environment",
    "data_posture",
    "workflows",
    "privacy",
    "decisions",
    "acceptance_scenarios"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": 1
    },
    "profile_name": {
      "type": "string",
      "minLength": 1
    },
    "requirements_status": {
      "enum": [
        "draft",
        "blocked_on_confirmation",
        "ready_for_implementation",
        "implemented"
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_name", "primary_goal"],
      "properties": {
        "display_name": {"type": "string", "minLength": 1},
        "primary_goal": {"type": "string", "minLength": 1}
      }
    },
    "requested_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "change_id",
          "category",
          "outcome",
          "priority",
          "decision_status"
        ],
        "properties": {
          "change_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "category": {
            "enum": [
              "terminology",
              "appearance",
              "workflow",
              "financial_model",
              "imports",
              "authentication_users",
              "hosting",
              "data_migration",
              "other"
            ]
          },
          "outcome": {"type": "string", "minLength": 1},
          "priority": {
            "enum": ["must_have", "should_have", "could_have", "deferred"]
          },
          "decision_status": {
            "enum": ["confirmed", "assumed", "unresolved", "deferred"]
          },
          "notes": {"type": "string"}
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "operating_system",
        "access_model",
        "data_location_preference",
        "backup_expectation",
        "network_access",
        "offline_requirement",
        "authentication_expectation"
      ],
      "properties": {
        "target": {
          "enum": [
            "local_web",
            "windows_desktop",
            "private_server",
            "private_cloud_vm",
            "undecided"
          ]
        },
        "operating_system": {"type": "string", "minLength": 1},
        "access_model": {
          "enum": [
            "one_trusted_user",
            "trusted_household",
            "private_authenticated_group",
            "public_or_untrusted",
            "undecided"
          ]
        },
        "data_location_preference": {"type": "string", "minLength": 1},
        "backup_expectation": {"type": "string", "minLength": 1},
        "network_access": {
          "enum": [
            "loopback_only",
            "private_network",
            "private_authenticated_network",
            "public_or_untrusted",
            "undecided"
          ]
        },
        "offline_requirement": {
          "enum": ["required", "preferred", "not_required", "undecided"]
        },
        "authentication_expectation": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    },
    "data_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "starting_point",
        "development_data",
        "migration_scope",
        "backup_before_data_change",
        "real_data_authorization_status"
      ],
      "properties": {
        "starting_point": {
          "enum": ["new_empty_workspace", "existing_ledger", "undecided"]
        },
        "development_data": {"const": "synthetic_only"},
        "migration_scope": {"type": "string", "minLength": 1},
        "backup_before_data_change": {
          "enum": ["required", "not_applicable", "unresolved"]
        },
        "real_data_authorization_status": {
          "enum": [
            "not_applicable",
            "not_granted",
            "explicit_named_copy_only"
          ]
        },
        "notes": {"type": "string"}
      }
    },
    "localization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currency": {"type": "string"},
        "locale": {"type": "string"},
        "date_format": {"type": "string"},
        "timezone": {"type": "string"}
      }
    },
    "terminology": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "envelope_singular": {"type": "string"},
        "envelope_plural": {"type": "string"},
        "savings_workflow_name": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "appearance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme_profile": {"type": "string", "minLength": 1},
        "notes": {"type": "string"},
        "accessibility_requirements": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "account_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role_id", "display_name", "purpose"],
        "properties": {
          "role_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "display_name": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1}
        }
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workflow_id",
          "decision_status",
          "trigger",
          "inputs",
          "rules",
          "review_point",
          "writes",
          "recovery",
          "privacy_demo",
          "success"
        ],
        "properties": {
          "workflow_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "decision_status": {
            "enum": ["confirmed", "assumed", "unresolved", "deferred"]
          },
          "trigger": {"type": "string", "minLength": 1},
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "rules": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "review_point": {"type": "string", "minLength": 1},
          "writes": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "recovery": {"type": "string", "minLength": 1},
          "privacy_demo": {"type": "string", "minLength": 1},
          "success": {"type": "string", "minLength": 1},
          "recorded_result": {"type": "string"}
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "real_data_allowed_for_development",
        "synthetic_demo_required",
        "credentials_may_be_stored_in_profile"
      ],
      "properties": {
        "real_data_allowed_for_development": {"const": false},
        "synthetic_demo_required": {"const": true},
        "credentials_may_be_stored_in_profile": {"const": false},
        "notes": {"type": "string"}
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "subject",
          "statement",
          "status",
          "confirmation_required",
          "consequence_if_wrong"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "subject": {"type": "string", "minLength": 1},
          "statement": {"type": "string", "minLength": 1},
          "status": {
            "enum": ["confirmed", "assumed", "unresolved", "deferred"]
          },
          "confirmation_required": {"type": "boolean"},
          "consequence_if_wrong": {"type": "string", "minLength": 1},
          "related_change_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          },
          "notes": {"type": "string"}
        }
      }
    },
    "acceptance_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario_id",
          "data_classification",
          "given",
          "when",
          "then",
          "covers_change_ids"
        ],
        "properties": {
          "scenario_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "data_classification": {"const": "synthetic"},
          "given": {"type": "string", "minLength": 1},
          "when": {"type": "string", "minLength": 1},
          "then": {"type": "string", "minLength": 1},
          "covers_change_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          },
          "financial_invariants": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "deferred": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "handoff_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
